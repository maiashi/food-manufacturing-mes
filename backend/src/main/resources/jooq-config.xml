<?xml version="1.0" encoding="UTF-8"?>
<configuration xmlns="http://www.jooq.org/jooq-codegen-config.xsd">
    <jdbc>
        <driver>org.postgresql.Driver</driver>
        <url>jdbc:postgresql://host.docker.internal:5432/mes_dev</url>
        <user>mes_admin</user>
        <password>mes_secret</password>
    </jdbc>
    <generator>
        <name>org.jooq.codegen.JavaGenerator</name>
        <database>
            <name>org.jooq.meta.postgres.PostgresDatabase</name>
            <inputSchema>public</inputSchema>
            <includes>.*</includes>
            <excludes>DATABASECHANGELOG|DATABASECHANGELOGLOCK|flyway_schema_history|SERVICE_LOCK</excludes>
        </database>
        <target>
            <packageName>com.mes.jooq.generated</packageName>
            <directory>/home/jooq/gen</directory>
        </target>
    </generator>
</configuration>
